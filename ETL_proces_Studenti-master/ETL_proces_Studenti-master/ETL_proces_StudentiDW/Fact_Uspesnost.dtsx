            <component
              refId="Package\ETL Fact_Uspesnost\Lookup prosecna_ocena_po_drzavi"
              componentClassID="Microsoft.Lookup"
              contactInfo="Lookup;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;6"
              description="Joins additional columns to the data flow by looking up values in a table. For example, join to the 'employee id' column the employees table to get 'hire date' and 'employee name'. We recommend this transformation when the lookup table can fit into memory."
              name="Lookup prosecna_ocena_po_drzavi"
              usesDispositions="true"
              version="6">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement that generates the lookup table."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    id_student,
    s.id_drzava_rodjenja,
    (
        SELECT AVG(CAST(r2.ocena AS float))
        FROM rezultat_ispita r2
        JOIN student s2 ON r2.id_student = s2.id_student
        WHERE r2.f_polozen = 1
          AND ISNUMERIC(r2.ocena) = 1
          AND CAST(r2.ocena AS int) BETWEEN 6 AND 10
          AND s2.id_drzava_rodjenja = s.id_drzava_rodjenja
    ) AS prosecna_ocena_po_drzavi
FROM student s
GROUP BY s.id_student, s.id_drzava_rodjenja
ORDER BY s.id_drzava_rodjenja;</property>
                <property
                  dataType="System.String"
                  description="Specifies a SQL statement that uses parameters to generate the lookup table."
                  expressionType="Notify"
                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (SELECT 
    id_student,
    s.id_drzava_rodjenja,
    (
        SELECT AVG(CAST(r2.ocena AS float))
        FROM rezultat_ispita r2
        JOIN student s2 ON r2.id_student = s2.id_student
        WHERE r2.f_polozen = 1
          AND ISNUMERIC(r2.ocena) = 1
          AND CAST(r2.ocena AS int) BETWEEN 6 AND 10
          AND s2.id_drzava_rodjenja = s.id_drzava_rodjenja
    ) AS prosecna_ocena_po_drzavi
FROM student s
GROUP BY s.id_student, s.id_drzava_rodjenja
ORDER BY s.id_drzava_rodjenja;) [refTable]
where [refTable].[id_student] = ?</property>
