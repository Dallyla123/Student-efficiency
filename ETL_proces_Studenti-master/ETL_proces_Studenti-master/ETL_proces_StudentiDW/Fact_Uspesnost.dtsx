        <SQLTask:SqlTaskData
          SQLTask:Connection="{3C9D213E-7D71-438B-81A5-2FB51A1CF082}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS &#xA;(SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'Fact_Uspesnost')) &#xA;BEGIN &#xA;DROP TABLE [dbo].[Fact_Uspesnost] &#xA;&#xA;CREATE TABLE [dbo].[Fact_Uspesnost](&#xA;&#x9;[uspesnost_SID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[vreme_SID] [int] NOT NULL,&#xA;&#x9;[student_SID] [int] NOT NULL,&#xA;&#x9;[prijava_SID] [int] NOT NULL,&#xA;&#x9;[predmet_SID] [int] NOT NULL,&#xA;&#x9;[prosecna_ocena_studenta] [float] NULL,&#xA;&#x9;[redni_broj_prijave_polozenog_ispita] [int] NULL,&#xA;&#x9;[prosecna_ocena_po_drzavi] [float] NULL,&#xA;&#x9;[prosecna_ocena_po_skoli] [float] NULL,&#xA;&#x9;[krajnja_ocena_na_predmetu] [int] NULL,&#xA; CONSTRAINT [PK_Fact_Uspesnost] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[uspesnost_SID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost]  WITH CHECK ADD  CONSTRAINT [FK_Fact_Uspesnost_Dim_Predmet] FOREIGN KEY([predmet_SID])&#xA;REFERENCES [dbo].[Dim_Predmet] ([predmet_SID])&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost] CHECK CONSTRAINT [FK_Fact_Uspesnost_Dim_Predmet]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost]  WITH CHECK ADD  CONSTRAINT [FK_Fact_Uspesnost_Dim_Prijava] FOREIGN KEY([prijava_SID])&#xA;REFERENCES [dbo].[Dim_Prijava] ([prijava_SID])&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost] CHECK CONSTRAINT [FK_Fact_Uspesnost_Dim_Prijava]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost]  WITH CHECK ADD  CONSTRAINT [FK_Fact_Uspesnost_Dim_Student] FOREIGN KEY([student_SID])&#xA;REFERENCES [dbo].[Dim_Student] ([student_SID])&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost] CHECK CONSTRAINT [FK_Fact_Uspesnost_Dim_Student]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost]  WITH CHECK ADD  CONSTRAINT [FK_Fact_Uspesnost_Dim_Vreme] FOREIGN KEY([vreme_SID])&#xA;REFERENCES [dbo].[Dim_Vreme] ([vreme_SID])&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Uspesnost] CHECK CONSTRAINT [FK_Fact_Uspesnost_Dim_Vreme]&#xA;END&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
