            <component
              refId="Package\ETL Fact_Uspesnost\Lookup broj_uspesne_prijave"
              componentClassID="Microsoft.Lookup"
              contactInfo="Lookup;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;6"
              description="Joins additional columns to the data flow by looking up values in a table. For example, join to the 'employee id' column the employees table to get 'hire date' and 'employee name'. We recommend this transformation when the lookup table can fit into memory."
              name="Lookup broj_uspesne_prijave"
              usesDispositions="true"
              version="6">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement that generates the lookup table."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">;WITH PoslednjiPokusaj AS (
    SELECT 
        id_student,
        id_predmet,
        id_rok,
        ocena,
        datum_polaganja,
        ROW_NUMBER() OVER (
            PARTITION BY id_student, id_predmet
            ORDER BY datum_polaganja DESC, id_rok DESC
        ) AS rn
    FROM rezultat_ispita
    WHERE f_polozen = 1
),
BrojPrijava AS (
    SELECT 
        id_student,
        id_predmet,
        COUNT(*) AS broj_prijava      -- ako želiš samo uspešne, dodaj WHERE f_polozen=1 ovde
    FROM rezultat_ispita
    GROUP BY id_student, id_predmet
)
SELECT 
    b.id_student,
    b.id_predmet,
    b.broj_prijava,
    p.id_rok,
    p.ocena AS krajnja_ocena,
    p.datum_polaganja
FROM BrojPrijava b
JOIN PoslednjiPokusaj p
  ON b.id_student = p.id_student
 AND b.id_predmet = p.id_predmet
WHERE p.rn = 1;</property>
                <property
                  dataType="System.String"
                  description="Specifies a SQL statement that uses parameters to generate the lookup table."
                  expressionType="Notify"
                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (;WITH PoslednjiPokusaj AS (
    SELECT 
        id_student,
        id_predmet,
        id_rok,
        ocena,
        datum_polaganja,
        ROW_NUMBER() OVER (
            PARTITION BY id_student, id_predmet
            ORDER BY datum_polaganja DESC, id_rok DESC
        ) AS rn
    FROM rezultat_ispita
    WHERE f_polozen = 1
),
BrojPrijava AS (
    SELECT 
        id_student,
        id_predmet,
        COUNT(*) AS broj_prijava      -- ako želiš samo uspešne, dodaj WHERE f_polozen=1 ovde
    FROM rezultat_ispita
    GROUP BY id_student, id_predmet
)
SELECT 
    b.id_student,
    b.id_predmet,
    b.broj_prijava,
    p.id_rok,
    p.ocena AS krajnja_ocena,
    p.datum_polaganja
FROM BrojPrijava b
JOIN PoslednjiPokusaj p
  ON b.id_student = p.id_student
 AND b.id_predmet = p.id_predmet
WHERE p.rn = 1;) [refTable]
where [refTable].[id_student] = ? and [refTable].[id_predmet] = ? and [refTable].[id_rok] = ?</property>
