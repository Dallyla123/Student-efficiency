      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3C9D213E-7D71-438B-81A5-2FB51A1CF082}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Fact_Uspesnost_Dim_Student'&#xA;)&#xA;BEGIN&#xA;    ALTER TABLE [dbo].[Fact_Uspesnost]&#xA;        DROP CONSTRAINT [FK_Fact_Uspesnost_Dim_Student];&#xA;END&#xA;&#xA;&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Dim_Prijava_Dim_Student'&#xA;)&#xA;BEGIN&#xA;    -- Ovaj FK je na Dim_Prijava (ne na Fact_Uspesnost)&#xA;    ALTER TABLE [dbo].[Dim_Prijava]&#xA;        DROP CONSTRAINT [FK_Dim_Prijava_Dim_Student];&#xA;END&#xA;&#xA;&#xA;IF EXISTS (&#xA;    SELECT * FROM sysobjects&#xA;    WHERE id = OBJECT_ID(N'[dbo].[Dim_Student]')&#xA;      AND xtype = 'U'&#xA;)&#xA;BEGIN&#xA;    DROP TABLE [dbo].[Dim_Student];&#xA;END&#xA;&#xA;CREATE TABLE [dbo].[Dim_Student](&#xA;&#x9;[student_SID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[id_student] [int] NOT NULL,&#xA;&#x9;[drzava_rodjenja] [nvarchar](100) NULL,&#xA;&#x9;[naziv_srednje_skole] [nvarchar](200) NULL,&#xA; CONSTRAINT [PK_Dim_Student] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[student_SID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
