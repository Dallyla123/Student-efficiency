                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT s.id_student, d.naziv as drzava_rodjenja, sr.naziv as naziv_srednje_skole
FROM student s LEFT JOIN sif_srednja_skola sr ON (s.id_srednja_skola=sr.id_srednja_skola) LEFT JOIN sif_drzava d ON (s.id_drzava_rodjenja=d.id_drzava);</property>
