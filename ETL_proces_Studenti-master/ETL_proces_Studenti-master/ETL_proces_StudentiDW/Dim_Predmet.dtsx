      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3C9D213E-7D71-438B-81A5-2FB51A1CF082}"
          SQLTask:SqlStatementSource="-- Provera i brisanje constrainta ako postoje&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS &#xA;    WHERE CONSTRAINT_NAME IN (&#xA;        'FK_Dim_Prijava_Dim_Predmet',&#xA;        'FK_Fact_Uspesnost_Dim_Predmet',&#xA;        'FK_Fact_efikasnost_nastave_Dim_Predmet'&#xA;    )&#xA;)&#xA;BEGIN&#xA;    -- Brisanje constrainta pojedinačno (mora jedan po jedan)&#xA;    IF EXISTS (SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_NAME = 'FK_Dim_Prijava_Dim_Predmet')&#xA;        ALTER TABLE [dbo].[Dim_Prijava] DROP CONSTRAINT [FK_Dim_Prijava_Dim_Predmet];&#xA;&#xA;    IF EXISTS (SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_NAME = 'FK_Fact_Uspesnost_Dim_Predmet')&#xA;        ALTER TABLE [dbo].[Fact_Uspesnost] DROP CONSTRAINT [FK_Fact_Uspesnost_Dim_Predmet];&#xA;&#xA;    IF EXISTS (SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_NAME = 'FK_Fact_efikasnost_nastave_Dim_Predmet')&#xA;        ALTER TABLE [dbo].[Fact_efikasnost_nastave] DROP CONSTRAINT [FK_Fact_efikasnost_nastave_Dim_Predmet];&#xA;END&#xA;&#xA;IF EXISTS &#xA;(SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'Dim_Predmet')) &#xA;BEGIN &#xA;DROP TABLE [dbo].[Dim_Predmet] &#xA;CREATE TABLE [dbo].[Dim_Predmet](&#xA;&#x9;[predmet_SID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[id_predmet] [int] NOT NULL,&#xA;&#x9;[ima_lab] [bit] NULL,&#xA;&#x9;[predmet_naziv] [nvarchar](100) NULL,&#xA; CONSTRAINT [PK_Dim_Predmet] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[predmet_SID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
