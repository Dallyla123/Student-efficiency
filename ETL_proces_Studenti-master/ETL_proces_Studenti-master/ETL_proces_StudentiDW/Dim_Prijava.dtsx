    <DTS:Executable
      DTS:refId="Package\Execute SQL Task"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{14D93087-ECA6-4470-8ED1-64C37B6403F6}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3C9D213E-7D71-438B-81A5-2FB51A1CF082}"
          SQLTask:SqlStatementSource="-- Provera i brisanje constrainta ako postoje&#xA;&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS &#xA;    WHERE CONSTRAINT_NAME IN (&#xA;        'FK_Dim_Prijava_Dim_Predmet',&#xA;&#x9;&#x9;'FK_Dim_Prijava_Dim_Student',&#xA;&#x9;&#x9;'FK_Dim_Prijava_Dim_Vreme',&#xA;        'FK_Fact_efikasnost_nastave_Dim_Prijava',&#xA;        'FK_Fact_Uspesnost_Dim_Prijava'&#xA;    )&#xA;)&#xA;-- Dim_Prijava -&gt; Dim_Predmet&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Dim_Prijava_Dim_Predmet'&#xA;)&#xA;    ALTER TABLE [dbo].[Dim_Prijava] DROP CONSTRAINT [FK_Dim_Prijava_Dim_Predmet];&#xA;&#xA;&#xA;-- Dim_Prijava -&gt; Dim_Student&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Dim_Prijava_Dim_Student'&#xA;)&#xA;    ALTER TABLE [dbo].[Dim_Prijava] DROP CONSTRAINT [FK_Dim_Prijava_Dim_Student];&#xA;&#xA;&#xA;-- Dim_Prijava -&gt; Dim_Vreme&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Dim_Prijava_Dim_Vreme'&#xA;)&#xA;    ALTER TABLE [dbo].[Dim_Prijava] DROP CONSTRAINT [FK_Dim_Prijava_Dim_Vreme];&#xA;&#xA;&#xA;-- Fact_efikasnost_nastave -&gt; Dim_Prijava&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Fact_efikasnost_nastave_Dim_Prijava'&#xA;)&#xA;    ALTER TABLE [dbo].[Fact_efikasnost_nastave] DROP CONSTRAINT [FK_Fact_efikasnost_nastave_Dim_Prijava];&#xA;&#xA;&#xA;-- Fact_Uspesnost -&gt; Dim_Prijava&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;    WHERE CONSTRAINT_NAME = 'FK_Fact_Uspesnost_Dim_Prijava'&#xA;)&#xA;    ALTER TABLE [dbo].[Fact_Uspesnost] DROP CONSTRAINT [FK_Fact_Uspesnost_Dim_Prijava];&#xA;&#xA;&#xA;&#xA;IF EXISTS &#xA;(SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'Dim_Prijava')) &#xA;BEGIN &#xA;DROP TABLE [dbo].[Dim_Prijava] &#xA;CREATE TABLE [dbo].[Dim_Prijava](&#xA;&#x9;[prijava_SID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[ocena] [nvarchar](50) NULL,&#xA;&#x9;[fk_rok] [int] NOT NULL,&#xA;&#x9;[fk_predmet] [int] NOT NULL,&#xA;&#x9;[fk_student] [int] NOT NULL,&#xA;&#x9;[f_polozen] [bit] NULL,&#xA; CONSTRAINT [PK_Dim_Prijava] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[prijava_SID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;/* === Dim_Prijava -&gt; Dim_Predmet === */&#xA;ALTER TABLE [dbo].[Dim_Prijava]&#xA;    ADD CONSTRAINT [FK_Dim_Prijava_Dim_Predmet]&#xA;    FOREIGN KEY ([fk_predmet]) REFERENCES [dbo].[Dim_Predmet]([predmet_SID]);&#xA;&#xA;&#xA;/* === Dim_Prijava -&gt; Dim_Student === */&#xA;ALTER TABLE [dbo].[Dim_Prijava]&#xA;    ADD CONSTRAINT [FK_Dim_Prijava_Dim_Student]&#xA;    FOREIGN KEY ([fk_student]) REFERENCES [dbo].[Dim_Student]([student_SID]);&#xA;&#xA;&#xA;/* === Dim_Prijava -&gt; Dim_Vreme === */&#xA;ALTER TABLE [dbo].[Dim_Prijava]&#xA;    ADD CONSTRAINT [FK_Dim_Prijava_Dim_Vreme]&#xA;    FOREIGN KEY ([fk_rok]) REFERENCES [dbo].[Dim_Vreme]([vreme_SID]);&#xA;&#xA;&#xA;END&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
