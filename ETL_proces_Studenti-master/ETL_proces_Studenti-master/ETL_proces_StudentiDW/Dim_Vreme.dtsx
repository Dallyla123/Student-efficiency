    <DTS:Executable
      DTS:refId="Package\Execute SQL Task"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{224AD3B4-5B48-4259-BC23-3D983952EE51}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{3C9D213E-7D71-438B-81A5-2FB51A1CF082}"
          SQLTask:SqlStatementSource="-- Provera i brisanje constrainta ako postoje&#xA;IF EXISTS (&#xA;    SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS &#xA;    WHERE CONSTRAINT_NAME IN (&#xA;        'FK_Fact_Uspesnost_Dim_Vreme',&#xA;        'FK_Fact_efikasnost_nastave_Dim_Vreme',&#xA;&#x9;&#x9;'FK_Dim_Prijava_Dim_Vreme'&#xA;    )&#xA;)&#xA;BEGIN&#xA;    -- Brisanje constrainta pojedinačno (mora jedan po jedan)&#xA;    IF EXISTS (SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_NAME = 'FK_Dim_Prijava_Dim_Vreme')&#xA;        ALTER TABLE [dbo].[Dim_Prijava] DROP CONSTRAINT [FK_Dim_Prijava_Dim_Vreme];&#xA;&#xA;    IF EXISTS (SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_NAME = 'FK_Fact_Uspesnost_Dim_Vreme')&#xA;        ALTER TABLE [dbo].[Fact_Uspesnost] DROP CONSTRAINT [FK_Fact_Uspesnost_Dim_Vreme];&#xA;&#xA;    IF EXISTS (SELECT * FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_NAME = 'FK_Fact_efikasnost_nastave_Dim_Vreme')&#xA;        ALTER TABLE [dbo].[Fact_efikasnost_nastave] DROP CONSTRAINT [FK_Fact_efikasnost_nastave_Dim_Vreme];&#xA;END&#xA;&#xA;IF EXISTS &#xA;(SELECT * FROM sysobjects WHERE id = OBJECT_ID(N'Dim_Vreme')) &#xA;BEGIN &#xA;DROP TABLE [dbo].[Dim_Vreme] &#xA;CREATE TABLE [dbo].[Dim_Vreme](&#xA;&#x9;[vreme_SID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[id_rok] [int] NOT NULL,&#xA;&#x9;[naziv_roka] [nvarchar](50) NULL,&#xA;&#x9;[skolska_godina] [smallint] NULL,&#xA; CONSTRAINT [PK_Dim_Vreme] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[vreme_SID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
