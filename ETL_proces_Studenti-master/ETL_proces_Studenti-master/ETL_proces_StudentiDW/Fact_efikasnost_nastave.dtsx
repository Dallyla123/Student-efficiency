            <component
              refId="Package\ETL Fact_Uspesnost\Lookup prosecna_ocena_sa_lab"
              componentClassID="Microsoft.Lookup"
              contactInfo="Lookup;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;6"
              description="Joins additional columns to the data flow by looking up values in a table. For example, join to the 'employee id' column the employees table to get 'hire date' and 'employee name'. We recommend this transformation when the lookup table can fit into memory."
              name="Lookup prosecna_ocena_sa_lab"
              usesDispositions="true"
              version="6">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement that generates the lookup table."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">-- prvo izračunamo ukupni prosek za predmete koji imaju lab
;WITH ProsekLab AS (
    SELECT
        CAST(
            SUM(CAST(r.ocena AS float)) / NULLIF(COUNT(*), 0)
            AS decimal(10,2)
        ) AS prosecna_ocena_sa_lab
    FROM dbo.rezultat_ispita AS r
    WHERE r.f_polozen = 1
      AND ISNUMERIC(r.ocena) = 1
      AND CAST(r.ocena AS int) BETWEEN 6 AND 10
      AND EXISTS (
            SELECT 1
            FROM dbo.angazovanje a
            WHERE a.id_predmet = r.id_predmet
              AND a.id_tip_nastave = 3
      )
)
-- sad prikažemo taj isti prosek uz svaki predmet koji ima lab
SELECT 
    DISTINCT r.id_predmet,
    p.prosecna_ocena_sa_lab
FROM dbo.rezultat_ispita r
CROSS JOIN ProsekLab p
WHERE EXISTS (
    SELECT 1
    FROM dbo.angazovanje a
    WHERE a.id_predmet = r.id_predmet
      AND a.id_tip_nastave = 3
)
ORDER BY r.id_predmet;</property>
                <property
                  dataType="System.String"
                  description="Specifies a SQL statement that uses parameters to generate the lookup table."
                  expressionType="Notify"
                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (-- prvo izračunamo ukupni prosek za predmete koji imaju lab
;WITH ProsekLab AS (
    SELECT
        CAST(
            SUM(CAST(r.ocena AS float)) / NULLIF(COUNT(*), 0)
            AS decimal(10,2)
        ) AS prosecna_ocena_sa_lab
    FROM dbo.rezultat_ispita AS r
    WHERE r.f_polozen = 1
      AND ISNUMERIC(r.ocena) = 1
      AND CAST(r.ocena AS int) BETWEEN 6 AND 10
      AND EXISTS (
            SELECT 1
            FROM dbo.angazovanje a
            WHERE a.id_predmet = r.id_predmet
              AND a.id_tip_nastave = 3
      )
)
-- sad prikažemo taj isti prosek uz svaki predmet koji ima lab
SELECT 
    DISTINCT r.id_predmet,
    p.prosecna_ocena_sa_lab
FROM dbo.rezultat_ispita r
CROSS JOIN ProsekLab p
WHERE EXISTS (
    SELECT 1
    FROM dbo.angazovanje a
    WHERE a.id_predmet = r.id_predmet
      AND a.id_tip_nastave = 3
)
ORDER BY r.id_predmet;) [refTable]
where [refTable].[id_predmet] = ?</property>
