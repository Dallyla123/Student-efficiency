                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    id_predmet,
    CAST(SUM(CASE WHEN f_polozen = 1 THEN 1 ELSE 0 END) AS decimal(10,4))
        / NULLIF(COUNT(*), 0) AS prolaznost_po_predmetu
FROM rezultat_ispita
GROUP BY id_predmet</property>
